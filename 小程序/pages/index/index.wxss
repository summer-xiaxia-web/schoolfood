}

.shop-info {
  flex: 1;
}

.shop-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.shop-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.shop-status {
  font-size: 22rpx;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* ==================== 热门商品推荐 ==================== */
.hot-section {
  padding: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-more {
  font-size: 26rpx;
  color: #00C6FF;
}

.hot-scroll {
  white-space: nowrap;
}

.hot-items {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 10rpx;
}

.hot-item {
  width: 240rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hot-image {
  width: 100%;
  height: 200rpx;
}

.hot-info {
  padding: 16rpx;
}

.hot-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hot-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF5E5E;
  display: block;
  margin-top: 8rpx;
}

.hot-sales {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.hot-arrow {
  font-size: 32rpx;
  color: #00C6FF;
  margin-bottom: 16rpx;
  animation: arrowPulse 1.5s infinite;
}

@keyframes arrowPulse {
  0%, 100% { opacity: 0.5; transform: translateX(0); }
  50% { opacity: 1; transform: translateX(8rpx); }
}



/* ==================== 中间广告区 ==================== */
.ad-box {
  margin: 20rpx 30rpx;
  text-align: center;
}

.ad-image {
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

/* ==================== 底部图片展示 ==================== */
.bottom-box {
  margin: 20rpx 30rpx 40rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.bottom-pic {
  width: calc(50% - 10rpx);
}

.bottom-image {
  width: 100%;
  height: 180rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

