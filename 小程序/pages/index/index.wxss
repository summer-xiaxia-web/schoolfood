}

/* 推荐结果 */
.recommend-result {
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #b0e6ff;
}

.result-title {
  font-size: 30rpx;
  color: #00A8E8;
  margin-bottom: 20rpx;
  font-weight: bold;
}

.dish-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 16rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
}

.dish-item image {
  width: 160rpx;
  height: 140rpx;
  border-radius: 14rpx;
  margin-right: 20rpx;
}

.dish-info {
  flex: 1;
}

.dish-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.dish-reason {
  font-size: 26rpx;
  color: #666;
  margin: 8rpx 0 12rpx;
}

.dish-price {
  color: #FF5E5E;
  font-size: 32rpx;
  font-weight: bold;
}

