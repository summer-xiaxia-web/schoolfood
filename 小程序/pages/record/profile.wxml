<view class="page">
  <view class="header">
    <view class="avatar-section" bindtap="chooseAvatar">
      <view class="avatar-wrap">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar"></image>
        <open-data wx:else type="userAvatarUrl" class="avatar"></open-data>
      </view>
    </view>
    <view class="user-name-wrap">
      <open-data type="userNickName" class="user-name"></open-data>
      <view class="user-level">普通会员</view>
    </view>
  </view>

  <view class="form-section">
    <view class="form-item">
      <view class="form-label">姓名</view>
      <input class="form-input" placeholder="请输入您的姓名" value="{{userInfo.name}}" bindinput="onNameInput" />
    </view>

    <view class="form-item">
      <view class="form-label">性别</view>
      <view class="gender-options">
        <view class="gender-option {{userInfo.gender === '男' ? 'active' : ''}}" bindtap="selectGender" data-gender="男">男</view>
        <view class="gender-option {{userInfo.gender === '女' ? 'active' : ''}}" bindtap="selectGender" data-gender="女">女</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">手机号</view>
      <view class="phone-wrap">
        <text class="phone-value">{{userInfo.phone || '请绑定手机号'}}</text>
        <view class="change-btn" bindtap="changePhone">更换</view>
      </view>
    </view>

    <view class="form-item">
      <view class="form-label">生日</view>
      <picker mode="date" value="{{userInfo.birthday}}" start="1900-01-01" end="{{today}}" bindchange="onBirthdayChange" disabled="{{userInfo.birthday ? true : false}}">
        <view class="birthday-wrap">
          <text wx:if="{{userInfo.birthday}}" class="birthday-value">{{userInfo.birthday}}</text>
          <text wx:else class="birthday-hint">完善生日，不错过惊喜</text>
          <text class="arrow">›</text>
        </view>
      </picker>
      <view class="form-tip">填写完不可修改</view>
    </view>

    <view class="form-item">
      <view class="form-label">详细地址</view>
      <view class="address-wrap" bindtap="goToAddress">
        <text class="address-value">{{userInfo.address || '请填写详细地址'}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="save-btn" bindtap="saveProfile">保存</view>

  <view class="account-link" bindtap="goToAccount">账号管理</view>
</view>

<view class="modal-overlay" wx:if="{{showPhoneModal}}" bindtap="closePhoneModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">更换手机号</view>
    <input class="modal-input" placeholder="请输入新手机号" value="{{newPhone}}" bindinput="onPhoneInput" type="number" />
    <view class="modal-buttons">
      <view class="modal-btn modal-btn-cancel" bindtap="closePhoneModal">取消</view>
      <view class="modal-btn modal-btn-confirm" bindtap="confirmPhoneChange">确定</view>
    </view>
  </view>
</view>