page {
  background: #FAF7F2;
  min-height: 100vh;
}

.page {
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #B8D4E3 0%, #A8C5D6 100%);
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-section {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(199, 91, 91, 0.2);
}

.avatar {
  width: 100%;
  height: 100%;
}



.user-name-wrap {
  text-align: center;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
}

.user-level {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.form-section {
  background: #FFFFFF;
  margin: -20rpx 20rpx 20rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(184, 212, 227, 0.2);
}

.form-item {
  padding: 25rpx 0;
  border-bottom: 1rpx solid rgba(184, 212, 227, 0.2);
  position: relative;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 15rpx;
}

.form-input {
  font-size: 30rpx;
  color: #6B7B8B;
  text-align: right;
}

.gender-options {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}

.gender-option {
  padding: 15rpx 40rpx;
  border-radius: 30rpx;
  background: #F5F5F5;
  font-size: 28rpx;
  color: #6B7B8B;
  transition: all 0.3s ease;
}

.gender-option.active {
  background: linear-gradient(135deg, #C75B5B 0%, #B84A4A 100%);
  color: #FFFFFF;
}

.phone-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.phone-value {
  font-size: 30rpx;
  color: #6B7B8B;
}

.change-btn {
  padding: 10rpx 25rpx;
  border: 2rpx solid #C75B5B;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #C75B5B;
}

.birthday-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.birthday-hint {
  font-size: 28rpx;
  color: #C75B5B;
  background: rgba(199, 91, 91, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
}

.birthday-value {
  font-size: 30rpx;
  color: #6B7B8B;
}

.form-tip {
  font-size: 24rpx;
  color: #9BA8B3;
  margin-top: 10rpx;
}

.address-wrap {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.address-value {
  font-size: 30rpx;
  color: #6B7B8B;
  flex: 1;
  text-align: right;
}

.arrow {
  font-size: 36rpx;
  color: #9BA8B3;
}

.save-btn {
  margin: 20rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #C75B5B 0%, #B84A4A 100%);
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 8rpx 25rpx rgba(199, 91, 91, 0.35);
}

.account-link {
  text-align: center;
  font-size: 28rpx;
  color: #9BA8B3;
  padding: 20rpx;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 580rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #333333;
  box-sizing: border-box;
}

.modal-input:focus {
  border-color: #C75B5B;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.modal-btn-cancel {
  background: #F5F5F5;
  color: #6B7B8B;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #C75B5B 0%, #B84A4A 100%);
  color: #FFFFFF;
}