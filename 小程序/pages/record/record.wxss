page {
  font-size: 32rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background-color: #FAF7F2;
}

.header {
  background: linear-gradient(135deg, #B8D4E3 0%, #FFFFFF 100%);
  margin: 0 30rpx;
  margin-top: 60rpx;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(184, 212, 227, 0.3);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 4rpx solid #B8D4E3;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.avatar open-data,
.avatar image {
  width: 100%;
  height: 100%;
}

.user-detail {
  margin-left: 25rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  display: block;
}

.user-level {
  font-size: 24rpx;
  color: #9BA8B3;
  margin-top: 8rpx;
}

.user-stats {
  display: flex;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  padding: 25rpx 15rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #C75B5B;
}

.stat-label {
  font-size: 24rpx;
  color: #6B7B8B;
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  background: rgba(184, 212, 227, 0.3);
}

.menu-grid {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  margin: -20rpx 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(184, 212, 227, 0.2);
  position: relative;
  z-index: 5;
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.menu-item:nth-child(1) .menu-icon {
  background: rgba(199, 91, 91, 0.1);
}

.menu-item:nth-child(2) .menu-icon {
  background: rgba(244, 114, 182, 0.1);
}

.menu-item:nth-child(3) .menu-icon {
  background: rgba(67, 160, 71, 0.1);
}

.menu-item:nth-child(4) .menu-icon {
  background: rgba(52, 131, 235, 0.1);
}

.menu-name {
  font-size: 26rpx;
  color: #333333;
}

.menu-badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  background: #C75B5B;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

.order-section {
  background: rgba(255, 255, 255, 0.9);
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(184, 212, 227, 0.1);
  position: relative;
  z-index: 5;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #9BA8B3;
}

.order-tabs {
  display: flex;
  justify-content: space-around;
}

.order-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.tab-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.tab-icon-img {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 10rpx;
}

.tab-name {
  font-size: 26rpx;
  color: #6B7B8B;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -20rpx;
  background: #C75B5B;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.content {
  background: rgba(255, 255, 255, 0.9);
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(184, 212, 227, 0.1);
  position: relative;
  z-index: 5;
}

.content .section-header {
  margin-bottom: 0;
}

.list-item {
  display: flex;
  padding: 25rpx 0;
  border-bottom: 1rpx solid rgba(184, 212, 227, 0.2);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-l {
  flex: 1;
}

.list-item-type {
  font-size: 30rpx;
  color: #333333;
}

.list-item-time {
  font-size: 24rpx;
  color: #9BA8B3;
  margin-top: 8rpx;
}

.list-item-r {
  line-height: 60rpx;
}

.list-item-r text {
  color: #C75B5B;
  font-weight: 600;
  font-size: 30rpx;
}

.list-empty {
  text-align: center;
  padding: 40rpx;
  color: #9BA8B3;
  font-size: 28rpx;
}

.settings-section {
  background: #FFFFFF;
  margin: 0 20rpx 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(184, 212, 227, 0.1);
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid rgba(184, 212, 227, 0.1);
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.settings-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.settings-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
}

.shop-info-section {
  background: #FFFFFF;
  margin: 0 20rpx 40rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(184, 212, 227, 0.1);
}

.shop-info-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #C75B5B;
  line-height: 1.2;
}

.shop-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(184, 212, 227, 0.1);
}

.shop-info-item:last-child {
  border-bottom: none;
}

.shop-info-label {
  font-size: 28rpx;
  color: #6B7B8B;
  flex-shrink: 0;
}

.shop-info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.shop-phone {
  color: #C75B5B;
  text-decoration: underline;
}

.status-open {
  color: #52c41a;
  font-weight: 600;
}

.status-closed {
  color: #C75B5B;
  font-weight: 600;
}
