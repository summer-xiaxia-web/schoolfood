<view class="content">
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  <view wx:else>
    <view class="content-title">请确认您的订单</view>
  
  <view class="delivery-info" wx:if="{{deliveryType === 'delivery'}}">
    <view class="delivery-icon">🚗</view>
    <view class="delivery-detail">
      <view class="delivery-label">外卖配送</view>
      <view class="delivery-address">{{addressInfo}}</view>
    </view>
  </view>
  <view class="delivery-info" wx:else>
    <view class="delivery-icon">🍽️</view>
    <view class="delivery-detail">
      <view class="delivery-label">到店取餐</view>
      <view class="delivery-address">请凭取餐码到店取餐</view>
    </view>
  </view>

  <view class="order">
    <view class="order-title">订单详情</view>
    <view class="order-list">
      <view class="order-item" wx:for="{{order_food}}" wx:key="id">
        <view class="order-item-l">
          <image class="order-item-image" mode="widthFix" src="{{item.image_url}}" />
          <view>
            <view class="order-item-name">{{item.name}}</view>
            <view class="order-item-number">x {{item.number}}</view>
          </view>
        </view>
        <view class="order-item-price">{{priceFormat(item.price * item.number)}}</view>
      </view>
      <view class="order-item" wx:if="{{deliveryType === 'delivery'}}">
        <view class="order-item-l">配送费</view>
        <view class="order-item-price">{{priceFormat(deliveryFee)}}</view>
      </view>
      <view class="order-item" wx:if="{{checkPromotion(promotion)}}">
        <view class="order-item-l">
          <i class="order-promotion-icon">减</i>满减优惠</view>
        <view class="order-promotion-price">- {{priceFormat(promotion)}}</view>
      </view>
      <view class="order-item">
        <view class="order-item-l">合计</view>
        <view class="order-total-price">{{priceFormat(totalPrice)}}</view>
      </view>
    </view>
  </view>
  <view class="content-comment">
      <label>备注</label>
      <textarea placeholder="如有其他要求，请输入备注" bindinput="comment"></textarea>
    </view>
  </view>
</view>
<view class="operate">
  <view class="operate-info">合计：{{priceFormat(totalPrice)}}</view>
  <view class="operate-submit" bindtap="pay">去支付</view>
</view>
<wxs module="priceFormat">
  module.exports = function(price) {
    return '¥ ' + parseFloat(price)
  }
</wxs>
<wxs module="checkPromotion">
  module.exports = function(promotion) {
    return parseFloat(promotion) > 0
  }
</wxs>